{
  "name": "arkinity",
  "version": "1.0.0",
  "description": "Arkinity desktop video feed with Electron launcher",
  "author": "Arkinity",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "launcher": "electron .",
    "build:exe": "electron-builder --win nsis",
    "build:dmg": "electron-builder --mac dmg",
    "build:mac": "electron-builder --mac",
    "build:linux:dir": "electron-builder --linux dir",
    "build:flatpak": "npm run build:linux:dir && flatpak-builder --force-clean --repo=flatpak/repo flatpak/build flatpak/com.arkinity.launcher.yml",
    "bundle:flatpak": "flatpak build-bundle flatpak/repo dist/Arkinity.flatpak com.arkinity.launcher"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "nodemon": "^2.0.22"
  },
  "build": {
    "appId": "com.arkinity.launcher",
    "productName": "Arkinity",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.js",
      "config.js",
      "index.html",
      "styles.css",
      "server.js",
      "recommender.js",
      "catagorize.py",
      "electron/**/*",
      "data/**/*",
      "scripts/**/*",
      "thumbs/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "category": "AudioVideo"
    }
  }
}
